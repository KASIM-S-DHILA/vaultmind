{
  "name": "vaultmind",
  "version": "1.0.0",
  "description": "Local AI for Legal & Confidential Intelligence — 100% offline RAG assistant",
  "main": "src/main/index.js",
  "homepage": "./",
  "author": {
    "name": "VaultMind",
    "email": "support@vaultmind.local"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite src/renderer --port 5173",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build src/renderer --outDir ../../dist/renderer",
    "build:electron": "electron-builder --win",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.12.0",
    "better-sqlite3": "^11.5.0",
    "electron-store": "^10.0.0",
    "fastembed": "^1.14.1",
    "node-llama-cpp": "^3.3.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.vaultmind.app",
    "productName": "VaultMind",
    "copyright": "Copyright © 2025 VaultMind",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/main/**/*",
      "dist/renderer/**/*",
      "!src/renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "models",
        "to": "models",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-llama-cpp/**",
      "node_modules/better-sqlite3/**",
      "node_modules/@lancedb/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "VaultMind-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VaultMind",
      "license": "LICENSE.md"
    }
  }
}
